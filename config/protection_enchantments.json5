{
	"fireProtectionEnchantment": {
		/* Items that can be enchanted
		   Allowed Values: ALL_ITEMS, ITEMS_AND_COMPATIBLE_BLOCKS, ITEMS_ONLY
		*/
		"enchantableItems": "ITEMS_AND_COMPATIBLE_BLOCKS",
		// Minimum experience cost required to apply the enchantment
		"minimumPower": 30,
		/* Enchantment Rarity (likelihood of obtaining the enchantment)
		   Allowed Values: COMMON, UNCOMMON, RARE, VERY_RARE
		*/
		"rarity": "VERY_RARE",
		// Whether to make it a treasure enchantment
		"treasureEnchantment": false,
		// Available through villager trading?
		"tradeable": true,
		// Should items glow when submerged in lava?
		"glow": false
	},
